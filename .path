[[ -f /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
[[ -f /usr/local/bin/brew ]] && eval "$(/usr/local/bin/brew shellenv)"
export PATH="$(brew --prefix)/bin:$(brew --prefix)/opt/python/libexec/bin:$HOME/.cargo/bin:$HOME/.config/yarn/global/node_modules/.bin:$HOME/.foundry/bin:$HOME/.local/bin:$HOME/.yarn/bin:$HOME/bin:$HOME/bin-private:$HOME/Documents/google-cloud-sdk/bin:/Applications/Sublime Text.app/Contents/SharedSupport/bin:/Applications/Wine Stable.app/Contents/Resources/start/bin:/Applications/Wine Stable.app/Contents/Resources/wine/bin:/opt/homebrew/opt/ruby/bin:/usr/local/heroku/bin:/usr/local/lib/ruby/gems/2.6.0/bin:/usr/local/opt/go/libexec/bin:/usr/local/opt/ruby/bin:/usr/local/sbin:/usr/local/share/npm/bin:${PATH}"
export DYLD_LIBRARY_PATH="${DYLD_LIBRARY_PATH}"
export LD_LIBRARY_PATH="${LD_LIBRARY_PATH}"
